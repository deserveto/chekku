# Combined deployment reference.
# For local development, copy agent/.env.example to agent/.env and
# client/.env.example to client/.env.local instead of using this file directly.

# Agent server
PORT=4111
HOST=localhost
DATABASE_URL=file:./mastra.db
DATABASE_AUTH_TOKEN=
LOG_LEVEL=info
MASTRA_TELEMETRY_DISABLED=true
WEB_URL=http://localhost:3000
LLM_BASE_URL=https://llm.rafiqspace.ai/v1
LLM_API_KEY=
LLM_DEFAULT_MODEL=qwen3.6-35b-a3b-fast
LLM_DISPLAY_NAME=Rafiqspace LLM
LLM_MODELS=qwen3.6-35b-a3b-fast,qwen3.6-35b-a3b
CHEKKU_DEFAULT_AGENT_ID=main-agent
BROWSER_HEADLESS=true

# Garage object storage
GARAGE_ENDPOINT=
GARAGE_REGION=
GARAGE_BUCKET=
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=

# Social Agent Telegram and email delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Chekku <onboarding@resend.dev>

# Client
AGENT_URL=http://localhost:4111
NEXT_PUBLIC_APP_URL=http://localhost:3000
CHEKKU_LOCAL_USER_ID=local-user
AGENT_SERVICE_TOKEN=
