NODE_ENV=development
PORT=4111
HOST=localhost

DATABASE_URL=file:./mastra.db
DATABASE_AUTH_TOKEN=

LOG_LEVEL=info
MASTRA_TELEMETRY_DISABLED=true
WEB_URL=http://localhost:3000

# One server-owned OpenAI-compatible endpoint.
# Never expose this key through a NEXT_PUBLIC_* variable.
LLM_BASE_URL=https://llm.rafiqspace.ai/v1
LLM_API_KEY=
LLM_DEFAULT_MODEL=qwen3.6-35b-a3b-fast
LLM_DISPLAY_NAME=Rafiqspace LLM

# Optional comma-separated fallback list when GET /models is unavailable.
LLM_MODELS=qwen3.6-35b-a3b-fast,qwen3.6-35b-a3b

CHEKKU_DEFAULT_AGENT_ID=main-agent
CHEKKU_LOCAL_USER_ID=local-user
BROWSER_HEADLESS=true

# Telegram adapter for the social-media-agent.
# Create a bot with BotFather (https://t.me/BotFather) and paste its token.
# TELEGRAM_MODE: polling (dev, no tunnel), webhook (prod, public URL), or auto.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
# Required only when TELEGRAM_MODE=webhook:
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
# TELEGRAM_BOT_USERNAME=

# Email outbound (Resend) for the send-email tool.
# Get a key at https://resend.com. The default sender below can only deliver
# to the account owner; production should use a Resend-verified domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Chekku <onboarding@resend.dev>
