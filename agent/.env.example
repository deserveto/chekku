NODE_ENV=development
PORT=4111
HOST=localhost

DATABASE_URL=file:./mastra.db
DATABASE_AUTH_TOKEN=

LOG_LEVEL=info
MASTRA_TELEMETRY_DISABLED=true
WEB_URL=http://localhost:3000

# One server-owned OpenAI-compatible endpoint.
# Never expose this key through a NEXT_PUBLIC_* variable.
LLM_BASE_URL=https://llm.rafiqspace.ai/v1
LLM_API_KEY=
LLM_DEFAULT_MODEL=qwen3.6-35b-a3b-fast
LLM_DISPLAY_NAME=Rafiqspace LLM

# Optional comma-separated fallback list when GET /models is unavailable.
LLM_MODELS=qwen3.6-35b-a3b-fast,qwen3.6-35b-a3b

CHEKKU_DEFAULT_AGENT_ID=main-agent
CHEKKU_LOCAL_USER_ID=local-user
BROWSER_HEADLESS=true

# QA Android Agent (Maestro). Disabled by default; requires the Maestro CLI, ADB, and an emulator/device.
MAESTRO_ENABLED=false
MAESTRO_COMMAND=maestro
MAESTRO_WORKSPACE=../maestro
MAESTRO_ARTIFACT_DIR=../artifacts/maestro
MAESTRO_TIMEOUT_MS=120000
ADB_PATH=adb

# Server-owned SearXNG search endpoint. Local scripts/dev.sh supplies this.
SEARXNG_BASE_URL=
# Optional bearer token for an authenticated external SearXNG reverse proxy.
SEARXNG_API_KEY=

# Garage object storage. scripts/dev.sh generates local values.
GARAGE_ENDPOINT=
GARAGE_REGION=
GARAGE_BUCKET=
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=

# Telegram adapter for the social-media-agent.
# TELEGRAM_MODE: polling (dev), webhook (prod), or auto.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Email outbound (Resend) for the send-email tool.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Chekku <onboarding@resend.dev>

# Recipient of the weekly social-draft review email (scheduled workflow).
# Required per environment — there is no default. When unset, the workflow
# still drafts and saves posts but skips the email step.
SOCIAL_DRAFT_REVIEW_EMAIL=
