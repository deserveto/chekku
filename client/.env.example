# Server-only upstream used by the Next.js proxy.
AGENT_URL=http://localhost:4111

# Public URL of this Next.js application.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Development identity seam. Replace with OIDC in production.
CHEKKU_LOCAL_USER_ID=local-user

# Optional server-to-server credential for the Mastra hop.
AGENT_SERVICE_TOKEN=
